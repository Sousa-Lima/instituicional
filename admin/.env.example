APP_NAME=Laravel
APP_ENV=local
APP_KEY=
# Docker Swarm: montar secret em ficheiro (alternativa ao APP_KEY em texto)
# APP_KEY_FILE=/run/secrets/slc_sousalima_app_key
FRONTEND_URL=https://sousalimaconsultoria.com.br
APP_DEBUG=true
APP_URL=http://localhost

# Fuso da aplicação (Carbon, agendamento). Alinhar com TZ do PHP/servidor.
APP_TIMEZONE=UTC

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=
# DB_PASSWORD_FILE=/run/secrets/slc_sousalima_db_password

# JWT (tymon/jwt-auth — ver config/jwt.php; login em POST /api/v1/auth/login)
# JWT_SECRET=
# JWT_SECRET_FILE=/run/secrets/slc_sousalima_jwt_secret
# php artisan jwt:secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Em Docker/Swarm sem extensão phpredis, usar predis (composer require predis/predis)
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
# MAIL_PASSWORD_FILE=/run/secrets/slc_sousalima_smtp_password
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Opcional: Bearer para GET de conteúdo e POST lead (alternativa ao JWT). Ver middleware api.public.
API_READ_TOKEN=

# Origens permitidas para CORS (POST lead). Separadas por vírgula.
CORS_ALLOWED_ORIGINS=https://sousalimaconsultoria.com.br,https://www.sousalimaconsultoria.com.br

# L5 Swagger (OpenAPI) — UI em /api/documentation; gerar JSON: php artisan l5-swagger:generate
# L5_SWAGGER_GENERATE_ALWAYS=false
# L5_SWAGGER_CONST_HOST=https://api.sousalimaconsultoria.com.br

# Filament Admin (painel visual)
# Emails permitidos para login no painel (/admin), separados por vírgula.
FILAMENT_ADMIN_EMAILS=admin@sousalimaconsultoria.com.br
