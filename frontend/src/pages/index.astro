---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import HomeServicesClient from '../components/HomeServicesClient.tsx';
import { fetchServicesListSafe } from '../lib/api-build';
import { absoluteUrl, DEFAULT_OG_IMAGE_PATH } from '../lib/site';

const servicesFromApi = await fetchServicesListSafe();
const logoAbsoluteUrl = absoluteUrl(
	Astro.site,
	'/sousa-lima-consultoria-logo-horizontal-colorido.png',
);
const shareImageUrl = absoluteUrl(Astro.site, DEFAULT_OG_IMAGE_PATH);
const showApiDevPanel = import.meta.env.DEV;

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: 'Sousa Lima Consultoria',
	url: 'https://sousalimaconsultoria.com.br',
	logo: logoAbsoluteUrl,
	image: shareImageUrl,
	description:
		'Consultoria especializada em viabilizar soluções de software e infraestrutura, com entregas em 30 a 90 dias.',
};
---

<BaseLayout
	title="Sousa Lima Consultoria — Transformação digital com foco em resultados"
	description="Consultoria especializada em viabilizar soluções de software e infraestrutura. MVP em 30 a 90 dias, unindo agilidade técnica à visão de negócio."
	jsonLd={jsonLd}
>
	<SiteHeader currentPath={Astro.url.pathname} />

	<main id="conteudo-principal" tabindex="-1" class="flex flex-1 flex-col">
		<section
			class="relative overflow-hidden bg-gradient-to-br from-slc-bg via-white to-slc-magenta/5 px-4 py-24 md:py-32"
		>
			<div class="mx-auto max-w-5xl">
				<p class="mb-3 text-sm font-semibold uppercase tracking-widest text-slc-navy">
					Institucional
				</p>
				<h1 class="font-display max-w-3xl text-4xl font-bold leading-tight text-slc-navy md:text-5xl">
					Transformação digital com foco em resultados e prazos reais.
				</h1>
				<p class="mt-6 max-w-2xl text-lg text-slc-text-muted">
					Consultoria especializada em viabilizar soluções de software e infraestrutura. Entregamos o seu MVP em
					30 a 90 dias, unindo agilidade técnica à visão de negócio.
				</p>
				<div class="mt-10 flex flex-wrap gap-4">
					<a
						href="/contato"
						class="inline-flex items-center justify-center rounded-lg bg-slc-navy px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-slc-navy/20 transition hover:bg-slc-indigo"
					>
						Agendar diagnóstico gratuito
					</a>
					<a
						href="/servicos"
						class="inline-flex items-center justify-center rounded-lg border border-slc-navy/15 bg-white px-6 py-3 text-sm font-semibold text-slc-navy transition hover:border-slc-magenta/40"
					>
						Conhecer nossos serviços
					</a>
				</div>
			</div>
		</section>

		<section id="servicos" class="border-t border-slc-grey/15 bg-white px-4 py-20">
			<div class="mx-auto max-w-5xl">
				<h2 class="font-display text-3xl font-semibold text-slc-navy md:text-4xl">
					Soluções sob medida para o estágio do seu negócio
				</h2>
				<p class="mt-3 max-w-2xl text-slc-text-muted">
					Alinhamos processos, software e cloud ao que a sua empresa precisa hoje — com entregas claras e
					mensuráveis.
				</p>

				{
					servicesFromApi.length > 0 ? (
						<div class="mt-12 grid gap-6 md:grid-cols-3">
							{servicesFromApi.map((s) => (
								<a
									href={`/servicos/${s.slug}`}
									class="group flex flex-col rounded-xl border border-slc-grey/15 bg-slc-bg/60 p-6 transition hover:border-slc-magenta/35 hover:shadow-md"
								>
									<h3 class="font-display text-lg font-semibold text-slc-navy group-hover:text-slc-purple">
										{s.title}
									</h3>
									<p class="mt-3 flex-1 text-sm text-slc-text-muted">
										{s.short_description ?? 'Ver detalhes do serviço.'}
									</p>
									<span class="mt-4 text-sm font-medium text-slc-purple">Ver mais →</span>
								</a>
							))}
						</div>
					) : (
						<HomeServicesClient client:visible />
					)
				}
			</div>
		</section>

		<section class="border-t border-slc-grey/15 bg-slc-bg px-4 py-20">
			<div class="mx-auto max-w-5xl">
				<h2 class="font-display text-3xl font-semibold text-slc-navy md:text-4xl">
					Parceiro estratégico, não apenas fornecedor
				</h2>
				<p class="mt-6 max-w-3xl text-lg text-slc-text-muted">
					Acreditamos na validação por ciclos. Em vez de projetos infinitos, trabalhamos com entregas contínuas e
					feedback real, garantindo que o software evolua conforme a necessidade do mercado.
				</p>
			</div>
		</section>

		<section id="cases" class="border-t border-slc-grey/15 bg-white px-4 py-20">
			<div class="mx-auto max-w-5xl">
				<h2 class="font-display text-3xl font-semibold text-slc-navy md:text-4xl">Resultados que geram valor</h2>
				<p class="mt-3 max-w-2xl text-slc-text-muted">
					Métricas abaixo são exemplos conceituais — substitua por dados reais quando disponíveis.
				</p>
				<ul class="mt-10 grid gap-6 md:grid-cols-3">
					<li class="rounded-xl border border-slc-grey/15 bg-slc-bg/80 p-6 text-center">
						<p class="font-display text-3xl font-bold text-slc-navy">+N</p>
						<p class="mt-2 text-sm text-slc-text-muted">projetos entregues com sucesso</p>
					</li>
					<li class="rounded-xl border border-slc-grey/15 bg-slc-bg/80 p-6 text-center">
						<p class="font-display text-3xl font-bold text-slc-navy">X%</p>
						<p class="mt-2 text-sm text-slc-text-muted">redução média em custos operacionais (exemplo)</p>
					</li>
					<li class="rounded-xl border border-slc-grey/15 bg-slc-bg/80 p-6 text-center">
						<p class="font-display text-3xl font-bold text-slc-navy">Y</p>
						<p class="mt-2 text-sm text-slc-text-muted">dias — prazo médio para primeira versão (fase 1)</p>
					</li>
				</ul>
				<div class="mt-10">
					<a
						href="/cases"
						class="inline-flex items-center justify-center rounded-lg border border-slc-navy/15 bg-white px-6 py-3 text-sm font-semibold text-slc-navy transition hover:border-slc-magenta/40"
					>
						Ver cases
					</a>
				</div>
			</div>
		</section>

		<section class="border-t border-slc-grey/15 bg-slc-bg px-4 py-20">
			<div class="mx-auto max-w-3xl">
				<h2 class="font-display text-3xl font-semibold text-slc-navy md:text-4xl">Perguntas frequentes</h2>
				<div class="mt-10 space-y-4">
					<details class="group rounded-xl border border-slc-grey/20 bg-white p-5 open:shadow-sm">
						<summary class="cursor-pointer font-medium text-slc-navy">
							Qual o tempo médio para ver o projeto funcionando?
						</summary>
						<p class="mt-3 text-slc-text-muted">
							Trabalhamos com modelos de 30, 60 ou 90 dias para a primeira fase (MVP), dependendo da
							complexidade.
						</p>
					</details>
					<details class="group rounded-xl border border-slc-grey/20 bg-white p-5 open:shadow-sm">
						<summary class="cursor-pointer font-medium text-slc-navy">
							Vocês atendem empresas que ainda estão validando a ideia?
						</summary>
						<p class="mt-3 text-slc-text-muted">
							Sim. O nosso foco é alinhar o escopo ao estágio atual do seu negócio para evitar desperdício de
							recursos.
						</p>
					</details>
				</div>
			</div>
		</section>

		<section id="contato" class="border-t border-slc-grey/15 bg-white px-4 py-20">
			<div class="mx-auto max-w-5xl text-center">
				<h2 class="font-display text-3xl font-semibold text-slc-navy md:text-4xl">Pronto para o próximo passo?</h2>
				<p class="mx-auto mt-4 max-w-xl text-slc-text-muted">
					Agende um diagnóstico gratuito ou envie uma mensagem — respondemos com objetividade.
				</p>
				<a
					href="/contato"
					class="mt-8 inline-flex items-center justify-center rounded-lg bg-slc-navy px-8 py-3 text-sm font-semibold text-white shadow-lg shadow-slc-navy/20 transition hover:bg-slc-indigo"
				>
					Ir para o formulário de contacto
				</a>
			</div>
		</section>

		{
			showApiDevPanel && (
				<section id="api-dev" class="border-t border-slc-grey/15 bg-slc-bg px-4 py-12">
					<div class="mx-auto max-w-5xl">
						<h2 class="font-display text-lg font-semibold text-slc-navy">API (apenas em dev)</h2>
						<p class="mt-2 text-sm text-slc-text-muted">
							<code class="rounded bg-white px-1.5 py-0.5 font-mono text-xs">PUBLIC_API_BASE_URL</code> e, no
							build, <code class="rounded bg-white px-1.5 py-0.5 font-mono text-xs">API_READ_TOKEN</code> no
							ambiente — não aparecem no bundle público.
						</p>
					</div>
				</section>
			)
		}
	</main>

	<SiteFooter />
</BaseLayout>
