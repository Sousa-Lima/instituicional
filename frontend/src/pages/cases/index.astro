---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { fetchCasesListSafe } from '../../lib/api-build';

const cases = await fetchCasesListSafe();
---

<BaseLayout
	title="Cases — Sousa Lima Consultoria"
	description="Projetos e resultados com clientes. Cases publicados pela equipa SLC."
>
	<SiteHeader currentPath={Astro.url.pathname} />
	<main id="conteudo-principal" tabindex="-1" class="flex flex-1 flex-col px-4 py-16">
		<div class="mx-auto w-full max-w-5xl">
			<h1 class="font-display text-4xl font-bold text-slc-navy">Cases</h1>
			<p class="mt-4 max-w-2xl text-slc-text-muted">
				Seleção de trabalhos publicados. Conteúdo carregado da API no tempo de build.
			</p>

			{
				cases.length === 0 ? (
					<p class="mt-12 rounded-xl border border-dashed border-slc-grey/30 bg-slc-bg p-8 text-center text-slc-text-muted">
						Nenhum case disponível. Configure <code class="font-mono text-sm">PUBLIC_API_BASE_URL</code> e{' '}
						<code class="font-mono text-sm">API_READ_TOKEN</code> no ambiente de build.
					</p>
				) : (
					<ul class="mt-12 grid gap-6 md:grid-cols-2">
						{cases.map((c) => (
							<li>
								<a
									href={`/cases/${c.slug}`}
									class="block h-full rounded-xl border border-slc-grey/15 bg-white p-6 shadow-sm transition hover:border-slc-magenta/30 hover:shadow-md"
								>
									{c.featured && (
										<span class="inline-block rounded-full bg-slc-magenta/10 px-2 py-0.5 text-xs font-semibold text-slc-navy">
											Destaque
										</span>
									)}
									<h2 class="font-display mt-2 text-xl font-semibold text-slc-navy">{c.title}</h2>
									{(c.customer_name || c.sector) && (
										<p class="mt-2 text-sm text-slc-text-muted">
											{[c.customer_name, c.sector].filter(Boolean).join(' · ')}
										</p>
									)}
									{c.short_summary && <p class="mt-3 text-sm text-slc-text-muted">{c.short_summary}</p>}
									<span class="mt-4 inline-block text-sm font-medium text-slc-purple">Ler case →</span>
								</a>
							</li>
						))}
					</ul>
				)
			}
		</div>
	</main>
	<SiteFooter />
</BaseLayout>
