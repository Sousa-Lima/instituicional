---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import CaseStudyDetailClient from '../../components/CaseStudyDetailClient.tsx';
import { fetchCasesListSafe, parseSlugEnvList } from '../../lib/api-build';
import { FALLBACK_CASE_SLUGS } from '../../lib/fallback-build-slugs';
import type { CaseStudyResource } from '../../types/api';

export async function getStaticPaths() {
	const list = await fetchCasesListSafe();
	if (list.length > 0) {
		return list.map((c: CaseStudyResource) => ({
			params: { slug: c.slug },
			props: { caseStudy: c },
		}));
	}
	const fromEnv = parseSlugEnvList(process.env.BUILD_SLUGS_CASES);
	const slugs = fromEnv.length > 0 ? fromEnv : [...FALLBACK_CASE_SLUGS];
	return slugs.map((slug) => ({
		params: { slug },
		props: { caseStudy: null },
	}));
}

interface Props {
	caseStudy: CaseStudyResource | null;
}

const { caseStudy } = Astro.props;
const slug = Astro.params.slug!;

const title = caseStudy
	? `${caseStudy.title} — Cases | Sousa Lima Consultoria`
	: 'Cases — Sousa Lima Consultoria';
const desc = caseStudy ? (caseStudy.short_summary ?? caseStudy.title) : 'Conteúdo do case.';
const hasCaseImage = Boolean(caseStudy?.main_image?.url);
---

<BaseLayout
	title={title}
	description={desc}
	ogType={hasCaseImage ? 'article' : 'website'}
	ogImage={caseStudy?.main_image?.url ?? undefined}
	ogImageAlt={hasCaseImage ? `${caseStudy!.title} — imagem do case` : undefined}
	ogImageWidth={hasCaseImage ? null : undefined}
	ogImageHeight={hasCaseImage ? null : undefined}
>
	<SiteHeader currentPath={Astro.url.pathname} />
	<main id="conteudo-principal" tabindex="-1" class="flex flex-1 flex-col px-4 py-16">
		<article class="mx-auto w-full max-w-3xl">
			{
				caseStudy ? (
					<>
						<p class="text-sm font-medium uppercase tracking-wider text-slc-navy">Case</p>
						<h1 class="font-display mt-2 text-4xl font-bold text-slc-navy">{caseStudy.title}</h1>
						{(caseStudy.customer_name || caseStudy.sector) && (
							<p class="mt-3 text-slc-text-muted">
								{[caseStudy.customer_name, caseStudy.sector].filter(Boolean).join(' · ')}
							</p>
						)}
						{caseStudy.short_summary && (
							<p class="mt-6 text-lg text-slc-text-muted">{caseStudy.short_summary}</p>
						)}
						{caseStudy.content_html && (
							<div
								class="slc-content mt-10 max-w-none text-slc-text [&_a]:text-slc-purple [&_a]:underline [&_h2]:mt-8 [&_h2]:font-display [&_h2]:text-2xl [&_h3]:mt-6 [&_p]:leading-relaxed"
								set:html={caseStudy.content_html}
							/>
						)}
						<p class="mt-12">
							<a href="/cases" class="text-sm font-medium text-slc-purple hover:text-slc-navy">
								← Todos os cases
							</a>
						</p>
					</>
				) : (
					<CaseStudyDetailClient client:load slug={slug} />
				)
			}
		</article>
	</main>
	<SiteFooter />
</BaseLayout>
