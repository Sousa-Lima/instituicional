---
import CookieConsent from '../components/CookieConsent.astro';
import '../styles/global.css';
import {
	absoluteUrl,
	DEFAULT_OG_IMAGE_HEIGHT,
	DEFAULT_OG_IMAGE_PATH,
	DEFAULT_OG_IMAGE_WIDTH,
	getSiteOrigin,
	SITE_NAME,
} from '../lib/site';

interface Props {
	title?: string;
	description?: string;
	/** Objeto ou lista de objetos JSON-LD (schema.org). */
	jsonLd?: Record<string, unknown> | Record<string, unknown>[];
	/** Caminho no site (ex. /imagem.png) ou URL absoluta — imagem em destaque para OG / Twitter. */
	ogImage?: string;
	ogImageAlt?: string;
	/** `null` omite og:image:width/height (ex.: imagem externa sem dimensões). */
	ogImageWidth?: number | null;
	ogImageHeight?: number | null;
	ogType?: 'website' | 'article';
	/** Twitter @handle (opcional), sem @ */
	twitterSite?: string;
	twitterCard?: 'summary' | 'summary_large_image';
	/** Evitar indexação (ex.: 404). */
	noindex?: boolean;
}

const {
	title = 'Sousa Lima Consultoria',
	description = 'Consultoria em processos, software e cloud para empresas que precisam escalar com segurança.',
	jsonLd,
	ogImage = DEFAULT_OG_IMAGE_PATH,
	ogImageAlt = `${SITE_NAME} — logotipo e identidade visual`,
	ogImageWidth,
	ogImageHeight,
	ogType = 'website',
	twitterSite,
	twitterCard = 'summary_large_image',
	noindex = false,
} = Astro.props;

const ogW =
	ogImageWidth === null ? null : (ogImageWidth ?? DEFAULT_OG_IMAGE_WIDTH);
const ogH =
	ogImageHeight === null ? null : (ogImageHeight ?? DEFAULT_OG_IMAGE_HEIGHT);

const canonicalUrl = absoluteUrl(Astro.site, Astro.url.pathname);
const ogImageUrl = absoluteUrl(Astro.site, ogImage);
const siteOrigin = getSiteOrigin(Astro.site);
const sitemapUrl = `${siteOrigin}/sitemap-index.xml`;

const jsonLdScript =
	jsonLd === undefined
		? null
		: Array.isArray(jsonLd)
			? JSON.stringify(jsonLd)
			: JSON.stringify(jsonLd);
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<title>{title}</title>
		{noindex ? (
			<meta name="robots" content="noindex, nofollow" />
		) : (
			<meta
				name="robots"
				content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
			/>
		)}
		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang="pt-BR" href={canonicalUrl} />
		<link rel="alternate" hreflang="x-default" href={canonicalUrl} />
		<link rel="sitemap" type="application/xml" title="Sitemap" href={sitemapUrl} />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="apple-touch-icon" href="/favicon.png" />
		<meta name="theme-color" content="#332c63" />
		<meta name="generator" content={Astro.generator} />

		<!-- Open Graph -->
		<meta property="og:type" content={ogType} />
		<meta property="og:site_name" content={SITE_NAME} />
		<meta property="og:locale" content="pt_BR" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:secure_url" content={ogImageUrl} />
		<meta property="og:image:type" content="image/png" />
		{
			ogW != null && ogH != null && (
				<>
					<meta property="og:image:width" content={String(ogW)} />
					<meta property="og:image:height" content={String(ogH)} />
				</>
			)
		}
		<meta property="og:image:alt" content={ogImageAlt} />

		<!-- Twitter / X -->
		<meta name="twitter:card" content={twitterCard} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		<meta name="twitter:image:alt" content={ogImageAlt} />
		{twitterSite && <meta name="twitter:site" content={`@${twitterSite.replace(/^@/, '')}`} />}
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=Outfit:wght@500;600;700&display=swap"
			rel="stylesheet"
		/>
		{
			jsonLdScript && (
				<script type="application/ld+json" set:html={jsonLdScript} />
			)
		}
	</head>
	<body class="min-h-dvh flex flex-col">
		<a class="slc-skip-link" href="#conteudo-principal">Saltar para o conteúdo principal</a>
		<slot />
		<CookieConsent />
	</body>
</html>
